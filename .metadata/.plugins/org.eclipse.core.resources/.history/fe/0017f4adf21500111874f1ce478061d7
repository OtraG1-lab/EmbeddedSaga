
//Led blinking program when button is pressed.
#include "driver/gpio.h"
#include "hal/gpio_types.h"
#define LED_PIN     32
#define BUTTON_PIN  4


void delay(void)
{
    for(volatile int i=0; i<200000; i++);
}

void app_main(void)
{
	
	//configuration part 
	
	gpio_set_direction(LED_PIN, GPIO_MODE_OUTPUT);      //set led pin as output  
	gpio_set_direction(BUTTON_PIN,  GPIO_MODE_INPUT);	//set button pin as input
	
	/*set button pin as pullup (~45K ohm reg),because at input GPIO pin behaves like high imepedence(floating)
	1.To prevent floating 
	2.Give stable default logic
	3.Avoid False trigger
	*/
	gpio_set_pull_mode(BUTTON_PIN, GPIO_PULLUP_ONLY);		 
	
	while(1)
	{
		if(gpio_get_level(BUTTON_PIN) ==0)				//read value from BUTTON_PIN
		{
			gpio_set_level(LED_PIN, 1);				//set value /turn ON LED
		}
		else
		{
			gpio_set_level(LED_PIN, 0);			//set value /turn OFF LED
		}
		/* Delay is used to rest CPU for some time for reducing bouncing effect, system stable*/
		delay();
		
	}
	
}

