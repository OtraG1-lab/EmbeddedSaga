#include <string.h>
#include "driver/uart.h"
#include "esp_log.h"

#define UART_PORT_NUM UART_NUM_0
#define BUF_SIZE 128

void app_main(void)
{
    uint8_t data[BUF_SIZE];

    // UART0 is already configured for USB, no pin setup needed
    ESP_LOGI("UART", "Type something and press ENTER");

    while (1)
    {
        int len = uart_read_bytes(
            UART_PORT_NUM,
            data,
            BUF_SIZE - 1,
            20 / portTICK_PERIOD_MS
        );

        if (len > 0)
        {
            data[len] = '\0';
            ESP_LOGI("UART", "You typed: %s", data);
        }
    }
}