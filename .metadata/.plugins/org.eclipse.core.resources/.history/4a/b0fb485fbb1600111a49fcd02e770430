#include <stdio.h>
#include "esp_log.h"
#include "nvs_flash.h"
#include "esp_bt.h"
#include "esp_bt_main.h"
#include "esp_gap_ble_api.h"
#include "esp_gatts_api.h"
#include "esp_bt_defs.h"
#include "driver/i2c.h"

#define GATTS_TAG "BLE_RTC"

// I2C pins for RTC DS3231
#define I2C_MASTER_SCL_IO 22
#define I2C_MASTER_SDA_IO 21
#define I2C_MASTER_NUM    I2C_NUM_0
#define I2C_MASTER_FREQ_HZ 100000
#define DS3231_ADDR 0x68

// BLE device name
#define DEVICE_NAME "ESP32_RTC_BLE"

// Standard BLE Current Time Service UUIDs
#define TIME_SERVICE_UUID 0x1805
#define CURRENT_TIME_CHAR_UUID 0x2A2B

// GATT handles
enum {
    IDX_SVC,
    IDX_CHAR,
    IDX_CHAR_VAL,
    HRS_IDX_NB
};

// Buffer to store RTC time
uint8_t rtc_time[7];  // second, minute, hour, day, date, month, year

// Convert BCD to decimal
uint8_t bcd2dec(uint8_t val){ return (val/16*10 + val%16); }

// -------- I2C Functions --------
void i2c_init() {
    i2c_config_t conf = {
        .mode = I2C_MODE_MASTER,
        .sda_io_num = I2C_MASTER_SDA_IO,
        .scl_io_num = I2C_MASTER_SCL_IO,
        .sda_pullup_en = GPIO_PULLUP_ENABLE,
        .scl_pullup_en = GPIO_PULLUP_ENABLE,
        .master.clk_speed = I2C_MASTER_FREQ_HZ
    };
    i2c_param_config(I2C_MASTER_NUM, &conf);
    i2c_driver_install(I2C_MASTER_NUM, conf.mode, 0, 0, 0);
}

// Read RTC time from DS3231
void read_rtc() {
    uint8_t reg = 0x00;
    i2c_cmd_handle_t cmd = i2c_cmd_link_create();

    i2c_master_start(cmd);
    i2c_master_write_byte(cmd, (DS3231_ADDR<<1)|I2C_MASTER_WRITE, true);
    i2c_master_write_byte(cmd, reg, true);
    i2c_master_start(cmd);
    i2c_master_write_byte(cmd, (DS3231_ADDR<<1)|I2C_MASTER_READ, true);
    i2c_master_read(cmd, rtc_time, 7, I2C_MASTER_LAST_NACK);
    i2c_master_stop(cmd);
    i2c_master_cmd_begin(I2C_MASTER_NUM, cmd, 1000/portTICK_PERIOD_MS);
    i2c_cmd_link_delete(cmd);

    for(int i=0;i<7;i++) rtc_time[i]=bcd2dec(rtc_time[i]);
}

// -------- GATT Database --------
static const uint16_t primary_service_uuid = ESP_GATT_UUID_PRI_SERVICE;
static const uint16_t char_decl_uuid = ESP_GATT_UUID_CHAR_DECLARE;
static const uint8_t char_prop_read_notify = ESP_GATT_CHAR_PROP_BIT_READ | ESP_GATT_CHAR_PROP_BIT_NOTIFY;

static esp_gatts_attr_db_t gatt_db[HRS_IDX_NB] = {
    // Service
    [IDX_SVC] = {
        {ESP_GATT_AUTO_RSP},
        {ESP_UUID_LEN_16,(uint8_t*)&primary_service_uuid, ESP_GATT_PERM_READ,
         sizeof(uint16_t), sizeof(TIME_SERVICE_UUID), (uint8_t*)&TIME_SERVICE_UUID}
    },
    // Characteristic declaration
    [IDX_CHAR] = {
        {ESP_GATT_AUTO_RSP},
        {ESP_UUID_LEN_16,(uint8_t*)&char_decl_uuid, ESP_GATT_PERM_READ,
         sizeof(uint8_t), sizeof(char_prop_read_notify), (uint8_t*)&char_prop_read_notify}
    },
    // Characteristic value
    [IDX_CHAR_VAL] = {
        {ESP_GATT_AUTO_RSP},
        {ESP_UUID_LEN_16,(uint8_t*)&CURRENT_TIME_CHAR_UUID, ESP_GATT_PERM_READ,
         sizeof(rtc_time), sizeof(rtc_time), rtc_time}
    }
};

// -------- GATT Event Handler --------
static void gatts_event_handler(esp_gatts_cb_event_t event,
                                esp_gatt_if_t gatts_if,
                                esp_ble_gatts_cb_param_t *param)
{
    switch(event){
        case ESP_GATTS_REG_EVT:
            ESP_LOGI(GATTS_TAG,"GATT Server Registered");
            // Set device name
            esp_ble_gap_set_device_name(DEVICE_NAME);
            // Start advertising
            esp_ble_gap_config_adv_data(&(esp_ble_adv_data_t){
                .set_scan_rsp=false,
                .include_name=true,
                .include_txpower=true,
                .flag=(ESP_BLE_ADV_FLAG_GEN_DISC | ESP_BLE_ADV_FLAG_BREDR_NOT_SPT)
            });
            // Create attributes table
            esp_ble_gatts_create_attr_tab(gatt_db,gatts_if,HRS_IDX_NB,0);
            break;

        case ESP_GATTS_READ_EVT:
            read_rtc(); // update rtc_time before sending
            ESP_LOGI(GATTS_TAG,"Client read RTC time: %02d:%02d:%02d",rtc_time[2],rtc_time[1],rtc_time[0]);
            break;

        default:
            break;
    }
}

// -------- Main Function --------
void app_main(void)
{
    // Initialize NVS
    esp_err_t ret = nvs_flash_init();
    if(ret == ESP_ERR_NVS_NO_FREE_PAGES || ret == ESP_ERR_NVS_NEW_VERSION_FOUND){
        ESP_ERROR_CHECK(nvs_flash_erase());
        ESP_ERROR_CHECK(nvs_flash_init());
    }

    // Initialize I2C for RTC
    i2c_init();

    // Initialize BLE stack
    esp_bt_controller_config_t bt_cfg = BT_CONTROLLER_INIT_CONFIG_DEFAULT();
    ESP_ERROR_CHECK(esp_bt_controller_init(&bt_cfg));
    ESP_ERROR_CHECK(esp_bt_controller_enable(ESP_BT_MODE_BLE));
    ESP_ERROR_CHECK(esp_bluedroid_init());
    ESP_ERROR_CHECK(esp_bluedroid_enable());

    // Register GATT callback
    esp_ble_gatts_register_callback(gatts_event_handler);

    ESP_LOGI(GATTS_TAG,"BLE RTC GATT Server started");
}